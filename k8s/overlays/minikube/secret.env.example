# Copy to "secret.env" (gitignored) and fill in real values.
# Generate a Django key:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=replace-with-generated-key
POSTGRES_USER=splitzy
POSTGRES_PASSWORD=change-me-locally
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Django admin superuser (used by k8s/base/superuser-job.yaml)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-strong-password
